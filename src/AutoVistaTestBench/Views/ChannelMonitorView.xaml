<UserControl x:Class="AutoVistaTestBench.Views.ChannelMonitorView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundDeepBrush}">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <!-- Header / stats -->
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="16"/>
            <!-- Channel list -->
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ── Header: Acquisition Stats ───────────────────────────────────── -->
        <Border Grid.Row="0" Style="{StaticResource CardStyle}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Fill="{StaticResource AccentAmberBrush}"
                             VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="REAL-TIME CHANNEL MONITOR"
                               Style="{StaticResource HeadingMediumStyle}"
                               Foreground="{StaticResource AccentAmberBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="1" Orientation="Horizontal"
                            VerticalAlignment="Center" Margin="0,0,24,0">
                    <TextBlock Text="UPDATE RATE: " Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding UpdateRate}"
                               FontFamily="Consolas" FontSize="13"
                               Foreground="{StaticResource AccentGreenBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            VerticalAlignment="Center">
                    <TextBlock Text="TOTAL UPDATES: " Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding TotalUpdateCount}"
                               FontFamily="Consolas" FontSize="13"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ── Channel Table ───────────────────────────────────────────────── -->
        <Border Grid.Row="2"
                Background="{StaticResource BackgroundCardBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1" CornerRadius="6">
            <Grid>
                <Grid.RowDefinitions>
                    <!-- Column headers -->
                    <RowDefinition Height="Auto"/>
                    <!-- Data rows -->
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Column headers row -->
                <Border Grid.Row="0"
                        Background="{StaticResource BackgroundPanelBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,0,0,1"
                        CornerRadius="6,6,0,0"
                        Padding="16,10">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="12"/>      <!-- Status LED -->
                            <ColumnDefinition Width="140"/>     <!-- Channel ID -->
                            <ColumnDefinition Width="200"/>     <!-- Name -->
                            <ColumnDefinition Width="100"/>     <!-- Module -->
                            <ColumnDefinition Width="80"/>      <!-- Type -->
                            <ColumnDefinition Width="140"/>     <!-- Value -->
                            <ColumnDefinition Width="80"/>      <!-- Status -->
                            <ColumnDefinition Width="*"/>       <!-- Bar -->
                            <ColumnDefinition Width="120"/>     <!-- Timestamp -->
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="1" Text="CHANNEL ID"
                                   Style="{StaticResource LabelStyle}" LetterSpacing="1"/>
                        <TextBlock Grid.Column="2" Text="NAME"
                                   Style="{StaticResource LabelStyle}" LetterSpacing="1"/>
                        <TextBlock Grid.Column="3" Text="MODULE"
                                   Style="{StaticResource LabelStyle}" LetterSpacing="1"/>
                        <TextBlock Grid.Column="4" Text="TYPE"
                                   Style="{StaticResource LabelStyle}" LetterSpacing="1"/>
                        <TextBlock Grid.Column="5" Text="LIVE VALUE"
                                   Style="{StaticResource LabelStyle}" LetterSpacing="1"/>
                        <TextBlock Grid.Column="6" Text="STATUS"
                                   Style="{StaticResource LabelStyle}" LetterSpacing="1"/>
                        <TextBlock Grid.Column="7" Text="LEVEL"
                                   Style="{StaticResource LabelStyle}" LetterSpacing="1"/>
                        <TextBlock Grid.Column="8" Text="UPDATED"
                                   Style="{StaticResource LabelStyle}" LetterSpacing="1"/>
                    </Grid>
                </Border>

                <!-- Scrollable data rows -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding Channels}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <!-- Each channel row -->
                                <Border Background="{Binding RowBackground}"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="16,10"
                                        Cursor="Hand">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="12"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="200"/>
                                            <ColumnDefinition Width="100"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="140"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="120"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Status LED -->
                                        <Ellipse Grid.Column="0"
                                                 Width="8" Height="8"
                                                 Fill="{Binding StatusColor}"
                                                 VerticalAlignment="Center">
                                            <Ellipse.Effect>
                                                <BlurEffect Radius="2"/>
                                            </Ellipse.Effect>
                                        </Ellipse>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Id}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Name}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding EcuModuleId}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding Type}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Live value — highlights in status color -->
                                        <TextBlock Grid.Column="5"
                                                   Text="{Binding ValueDisplay}"
                                                   FontFamily="Consolas" FontSize="14"
                                                   FontWeight="SemiBold"
                                                   Foreground="{Binding ValueColor}"
                                                   VerticalAlignment="Center"/>

                                        <!-- Status badge -->
                                        <Border Grid.Column="6"
                                                Background="Transparent"
                                                VerticalAlignment="Center"
                                                HorizontalAlignment="Left">
                                            <TextBlock Text="{Binding StatusLabel}"
                                                       FontFamily="Consolas" FontSize="10"
                                                       Foreground="{Binding StatusColor}"/>
                                        </Border>

                                        <!-- Normalized level bar -->
                                        <Grid Grid.Column="7"
                                              VerticalAlignment="Center"
                                              Margin="8,0">
                                            <Border Background="{StaticResource BackgroundPanelBrush}"
                                                    Height="8" CornerRadius="4"/>
                                            <Border Height="8" CornerRadius="4"
                                                    HorizontalAlignment="Left"
                                                    MinWidth="2">
                                                <Border.Width>
                                                    <MultiBinding>
                                                        <MultiBinding.Converter>
                                                            <local:WidthFromNormalizedConverter
                                                                xmlns:local="clr-namespace:AutoVistaTestBench.Converters"/>
                                                        </MultiBinding.Converter>
                                                        <Binding Path="NormalizedValue"/>
                                                        <Binding Path="ActualWidth"
                                                                 RelativeSource="{RelativeSource AncestorType=Grid}"/>
                                                    </MultiBinding>
                                                </Border.Width>
                                                <Border.Background>
                                                    <SolidColorBrush Color="{Binding StatusColor.Color}"/>
                                                </Border.Background>
                                            </Border>
                                        </Grid>

                                        <TextBlock Grid.Column="8"
                                                   Text="{Binding LastUpdatedDisplay}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>
    </Grid>
</UserControl>