<UserControl x:Class="AutoVistaTestBench.Views.LogAnalyzerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="{StaticResource BackgroundDeepBrush}">

    <Grid Margin="20">
        <Grid.ColumnDefinitions>
            <!-- Log viewer (left panel) -->
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="16"/>
            <!-- AI Analysis (right panel) -->
            <ColumnDefinition Width="380"/>
        </Grid.ColumnDefinitions>

        <!-- ── Left Panel: Log Viewer ───────────────────────────────────────── -->
        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="12"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Log header -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentAmberBrush}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="SESSION LOG VIEWER"
                                   Style="{StaticResource HeadingMediumStyle}"
                                   Foreground="{StaticResource AccentAmberBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>

                    <Button Grid.Column="1"
                            Content="Clear"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding ClearLogCommand}"/>
                </Grid>
            </Border>

            <!-- Filter controls -->
            <Border Grid.Row="2" Style="{StaticResource CardStyle}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="MIN SEVERITY:" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="0,0,8,0" LetterSpacing="1"/>
                    <ComboBox ItemsSource="{Binding AvailableSeverities}"
                              SelectedItem="{Binding MinimumSeverityFilter}"
                              Style="{StaticResource InputComboBoxStyle}"
                              Width="120"/>
                    <TextBlock Text="LOG FILE:" Style="{StaticResource LabelStyle}"
                               VerticalAlignment="Center" Margin="24,0,8,0" LetterSpacing="1"/>
                    <TextBlock Text="{Binding LogFilePath}"
                               FontFamily="Consolas" FontSize="10"
                               Foreground="{StaticResource AccentBlueBrush}"
                               VerticalAlignment="Center"
                               TextTrimming="CharacterEllipsis"
                               MaxWidth="300"/>
                </StackPanel>
            </Border>

            <!-- Log entries list -->
            <Border Grid.Row="4"
                    Background="{StaticResource BackgroundPanelBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding LogEntries}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,6"
                                        BorderBrush="{StaticResource BorderSubtleBrush}"
                                        BorderThickness="0,0,0,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="180"/>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="160"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>

                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Timestamp, StringFormat={}{0:HH:mm:ss.fff}}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Severity}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   VerticalAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Error">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Critical">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Warning">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentAmberBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Info">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBlueBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Severity}" Value="Debug">
                                                            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Source}"
                                                   FontFamily="Consolas" FontSize="10"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="{Binding Message}"
                                                   FontFamily="Consolas" FontSize="11"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextWrapping="Wrap"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>
        </Grid>

        <!-- ── Right Panel: AI Analysis ─────────────────────────────────────── -->
        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="16"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- AI Analysis header + button -->
            <Border Grid.Row="0" Style="{StaticResource CardStyle}">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Ellipse Width="8" Height="8" Fill="{StaticResource AccentBlueBrush}"
                                 VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="AI LOG ANALYSIS"
                                   Style="{StaticResource HeadingMediumStyle}"
                                   Foreground="{StaticResource AccentBlueBrush}"/>
                    </StackPanel>

                    <TextBlock TextWrapping="Wrap" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,12"
                               Text="Send current session logs to Claude AI for automated root cause analysis and diagnostic recommendations."/>

                    <Button Content="⚡  Analyze Logs with AI"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding AnalyzeWithAiCommand}"
                            HorizontalAlignment="Stretch"/>

                    <!-- Loading indicator -->
                    <TextBlock Text="⏳ Analyzing..." FontSize="11"
                               Foreground="{StaticResource AccentAmberBrush}"
                               Margin="0,8,0,0"
                               HorizontalAlignment="Center">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAnalyzing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- AI Analysis result text area -->
            <Border Grid.Row="2"
                    Background="{StaticResource BackgroundCardBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="6">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="16">
                    <TextBlock Text="{Binding AiAnalysisResult}"
                               FontSize="12"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               TextWrapping="Wrap"
                               LineHeight="20"/>
                </ScrollViewer>
            </Border>
        </Grid>
    </Grid>
</UserControl>